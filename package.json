{
  "name": "mimo-tts-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "MiMo V2.5 TTS Studio - 语音合成、声音设计、声音克隆一站式工具",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
